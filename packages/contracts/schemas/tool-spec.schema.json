{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://at72.verse/schemas/tool-spec.json",
  "title": "ToolSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "description",
    "input_schema",
    "output_schema",
    "side_effect",
    "auth",
    "timeout_ms",
    "permission"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "side_effect": { "type": "boolean" },
    "auth": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["oauth", "api_key", "none"] }
      }
    },
    "timeout_ms": { "type": "integer", "minimum": 1 },
    "retry_policy": {
      "type": "object",
      "required": ["max_attempts", "backoff_ms"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 0 },
        "backoff_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "rate_limit": {
      "type": "object",
      "required": ["max_per_minute"],
      "properties": {
        "max_per_minute": { "type": "integer", "minimum": 1 }
      }
    },
    "permission": { "type": "string", "minLength": 1 },
    "categories": { "type": "array", "items": { "type": "string" } },
    "package": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "tool" },
        "package_id": { "type": "string" }
      }
    }
  }
}
