{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://at72.verse/schemas/skill-spec.json",
  "title": "SkillSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "name", "description", "input_schema", "output_schema"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "required_tools": { "type": "array", "items": { "type": "string" } },
    "optional_tools": { "type": "array", "items": { "type": "string" } },
    "default_model_profile": { "type": "string" },
    "persona_hints": {
      "type": "object",
      "properties": {
        "prefer_style": { "type": "string" }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "eval_suite": { "type": "string" },
    "permissions": { "type": "array", "items": { "type": "string" } }
  }
}
