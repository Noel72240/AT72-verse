{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://at72.verse/schemas/package-manifest.json",
  "title": "PackageManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "version",
    "publisher",
    "display_name",
    "description",
    "contracts",
    "permissions_requested",
    "resources"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["agent", "skill", "tool", "workflow", "prompt_pack"]
    },
    "version": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "icons": { "type": "array", "items": { "type": "string" } },
    "contracts": {
      "type": "object",
      "required": ["min_core", "min_kernel"],
      "properties": {
        "min_core": { "type": "string" },
        "min_kernel": { "type": "string" }
      }
    },
    "permissions_requested": { "type": "array", "items": { "type": "string" } },
    "resources": {
      "type": "object",
      "required": ["entrypoint", "manifests"],
      "properties": {
        "entrypoint": { "type": "string" },
        "manifests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "signature": {
      "type": "object",
      "required": ["alg", "digest"],
      "properties": {
        "alg": { "type": "string" },
        "digest": { "type": "string" },
        "cert_chain_ref": { "type": "string" }
      }
    },
    "pricing": {
      "type": "object",
      "required": ["model"],
      "properties": {
        "model": { "type": "string", "enum": ["free", "subscription", "usage"] },
        "notes": { "type": "string" }
      }
    },
    "categories": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
