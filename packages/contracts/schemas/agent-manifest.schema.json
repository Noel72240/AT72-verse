{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://at72.verse/schemas/agent-manifest.json",
  "title": "AgentManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "role",
    "description",
    "kind",
    "default_persona",
    "skills",
    "tools_allowlist",
    "memory_scopes",
    "default_model_profile",
    "constraints"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "kind": { "type": "string", "enum": ["orchestrator", "specialist", "utility"] },
    "default_persona": { "type": "string", "minLength": 1 },
    "skills": { "type": "array", "items": { "type": "string" } },
    "tools_allowlist": { "type": "array", "items": { "type": "string" } },
    "memory_scopes": { "type": "array", "items": { "type": "string" } },
    "default_model_profile": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_tokens_per_run", "max_tool_calls", "max_skill_invocations", "timeout_ms"],
      "properties": {
        "max_tokens_per_run": { "type": "integer", "minimum": 1 },
        "max_tool_calls": { "type": "integer", "minimum": 0 },
        "max_skill_invocations": { "type": "integer", "minimum": 0 },
        "timeout_ms": { "type": "integer", "minimum": 1 }
      }
    },
    "routing_hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "skill_tags": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "integer" }
      }
    },
    "can_consult": { "type": "array", "items": { "type": "string" } },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "avatar": { "type": "string" },
        "color_token": { "type": "string" },
        "short_label": { "type": "string" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "agent" },
        "package_id": { "type": "string" }
      }
    }
  }
}
