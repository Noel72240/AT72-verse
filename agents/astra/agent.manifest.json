{
  "id": "astra",
  "name": "Astra",
  "version": "0.1.0",
  "role": "specialist",
  "description": "SEO specialist — audit via skill.seo only.",
  "kind": "specialist",
  "default_persona": "persona.astra.default",
  "skills": ["skill.seo"],
  "tools_allowlist": ["seo-audit", "web-search"],
  "memory_scopes": ["run", "conversation"],
  "default_model_profile": "analytic-strict",
  "constraints": {
    "max_tokens_per_run": 50000,
    "max_tool_calls": 20,
    "max_skill_invocations": 20,
    "timeout_ms": 300000
  },
  "routing_hints": {
    "keywords": ["seo", "audit", "ranking", "serp"],
    "priority": 50
  }
}
