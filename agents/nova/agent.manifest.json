{
  "id": "nova",
  "name": "Nova",
  "version": "0.1.0",
  "role": "specialist",
  "description": "Content specialist — writing and copy via skill.writing only.",
  "kind": "specialist",
  "default_persona": "persona.nova.default",
  "skills": ["skill.writing"],
  "tools_allowlist": ["web-search", "file-read-write"],
  "can_consult": ["astra"],
  "memory_scopes": ["run", "conversation"],
  "default_model_profile": "creative-balanced",
  "constraints": {
    "max_tokens_per_run": 50000,
    "max_tool_calls": 20,
    "max_skill_invocations": 20,
    "timeout_ms": 300000
  },
  "routing_hints": {
    "keywords": ["write", "copy", "content", "post"],
    "priority": 50
  }
}
