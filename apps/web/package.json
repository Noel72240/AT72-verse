{
  "name": "@at72-verse/web",
  "version": "0.0.0",
  "private": true,
  "description": "Next.js 15 SaaS web application (Phase 16)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
