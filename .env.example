# AT72 Verse — local development defaults (Phase 03+)
# Copy to `.env` for local overrides: `cp .env.example .env`
# Never commit real secrets. These values are for local Docker only.

# --- PostgreSQL ---
POSTGRES_USER=verse
POSTGRES_PASSWORD=verse
POSTGRES_DB=verse
POSTGRES_PORT=5432
DATABASE_URL=postgresql://verse:verse@localhost:5432/verse?schema=public

# --- Redis (cache, BullMQ later, Redis Streams bus MVP — Phase 10) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# Without REDIS_URL, @at72-verse/bus uses InMemoryBus (unit / local fallback)

# --- Web (Phase 16) ---
# Local:
# NEXT_PUBLIC_API_URL=http://localhost:3001
# WEB_ORIGIN=http://localhost:3000
# Vercel (apps/web) — set in project env before build:
# NEXT_PUBLIC_API_URL=https://<your-api-host>
# On the API host, mirror the Vercel URL:
# WEB_ORIGIN=https://<your-app>.vercel.app

# --- MinIO (optional — start with: pnpm docker:up:minio) ---
MINIO_ROOT_USER=verse_minio
MINIO_ROOT_PASSWORD=verse_minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=verse_minio
S3_SECRET_KEY=verse_minio_secret
S3_BUCKET=verse-local
S3_REGION=us-east-1

# --- LLM (Phase 13 / AV1 — platform keys only; ADR-005 BYOK off) ---
# OPENAI_API_KEY=
# LLM_API_KEY=          # alias accepted by Credential Resolver

# --- Auth (Phase 05, ADR-004) ---
AUTH_PROVIDER=dev
# CLERK_SECRET_KEY=
# CLERK_PUBLISHABLE_KEY=
API_PORT=3001

# --- Kernel backend (Phase 08, Decision L2) — agents never read this ---
# stub = CI/tests reference (default) · core = in-process Verse Core wiring demo
# VERSE_KERNEL_BACKEND=stub

# --- Quotas / rate limits (Phase 31) ---
# VERSE_RATE_LIMIT_FAIL_OPEN=1

# --- Auth rate limits (Phase 33 / ED5bis) — pack defaults shown ---
# VERSE_AUTH_RL_LOGIN_LIMIT=20
# VERSE_AUTH_RL_LOGIN_WINDOW_SEC=900
# VERSE_AUTH_RL_INVITE_LIMIT=30
# VERSE_AUTH_RL_INVITE_WINDOW_SEC=900
# VERSE_AUTH_RL_WEBHOOK_LIMIT=120
# VERSE_AUTH_RL_WEBHOOK_WINDOW_SEC=60

# --- CSP report-only (Phase 33 / ED6bis) ---
# VERSE_CSP_REPORT_ENABLED=0          # disable reporting in local dev
# VERSE_CSP_REPORT_URI=http://localhost:3001/csp-report
# NEXT_PUBLIC_CSP_REPORT_URI=http://localhost:3001/csp-report
# VERSE_CSP_ENFORCE=1                 # reserved — do NOT enable in Phase 33

# --- Billing & Payment Providers (Phase 34) ---
# PAYMENT_PROVIDER selects the adapter; business code never imports vendor SDKs.
PAYMENT_PROVIDER=sumup
# SumUp (when PAYMENT_PROVIDER=sumup)
# SUMUP_API_KEY=
# SUMUP_MERCHANT_CODE=
# SUMUP_WEBHOOK_SECRET=
# Plan amounts in cents (provider-agnostic)
VERSE_PLAN_PRICE_PRO_CENTS=2900
VERSE_PLAN_PRICE_ENTERPRISE_CENTS=9900
VERSE_BILLING_GRACE_DAYS=3
VERSE_BILLING_CURRENCY=EUR
# Force stub checkout (no live SumUp) — also used when SUMUP_API_KEY is unset
# VERSE_PAYMENT_STUB=1
